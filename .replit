modules = ["nodejs-24", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/grocery-split"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "cloudrun"
build = [
  "sh",
  "-c",
  "cd artifacts/grocery-split && BASE_PATH=/ PORT=3000 npm run build",
]

[workflows]
runButton = "Project"

